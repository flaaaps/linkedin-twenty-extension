{
  "manifest_version": 3,
  "name": "LinkedIn Twenty CRM",
  "version": "1.0.0",
  "description": "Quickly add and manage LinkedIn contacts in your Twenty CRM",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://crm.studypilot.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "LinkedIn Twenty CRM",
    "default_popup": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
